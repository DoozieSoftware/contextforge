{
  "name": "contextforge",
  "version": "0.1.1",
  "description": "Token-efficient context packages for any AI tool. Terminal-first CLI for understanding, tracing, reviewing, breaking down, and proposing \u2014 all backed by a small scanner-built context package.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "ctx": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && find dist -type f \\( -name \"*.d.ts\" -o -name \"*.d.ts.map\" -o -name \"*.js.map\" \\) -delete && chmod +x dist/cli.js",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "test:live": "CTX_LIVE=1 vitest run tests/e2e",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "gpt-tokenizer": "^2.5.0",
    "inquirer": "^12.11.1",
    "simple-git": "^3.27.0"
  },
  "optionalDependencies": {
    "tree-sitter-php": "^0.22.0",
    "tree-sitter-python": "^0.22.0",
    "tree-sitter-typescript": "^0.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "keywords": [
    "ai",
    "context",
    "cli",
    "tokens",
    "scanner",
    "llm"
  ]
}